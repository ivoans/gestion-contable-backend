# ============================================================
# Variables de entorno requeridas
# ============================================================

# Firma y verificación de tokens JWT
JWT_SECRET=changeme-use-a-long-random-string

# URL del proyecto Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key de Supabase (bypasea RLS — tratar como secreto)
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# API key de Resend para envío de emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Secreto para autorizar el endpoint /api/internal/run-cron
# Debe enviarse en el header x-cron-secret
CRON_SECRET=changeme-cron-trigger-secret

# Mecanismo de cron — elegir UNO (no configurar ambos: doble procesamiento):
#   internal (default): node-cron in-process corre los jobs a las 08:00 ART.
#   external: el server NO agenda nada; un scheduler externo (cron del host,
#             GitHub Actions, etc.) debe llamar POST /api/internal/run-cron
#             con el header x-cron-secret. Usar en entornos serverless o con
#             múltiples instancias (node-cron correría en cada una).
CRON_SCHEDULER=internal

# ============================================================
# Variables opcionales
# ============================================================

# Puerto HTTP para desarrollo (default: 3000)
PORT=3000

# CSV de orígenes permitidos por CORS. Vacío bloquea todo navegador con Origin.
ALLOWED_ORIGINS=http://localhost:5173,https://estudiocontablest.com.ar

# Dominio raíz para la cookie csrf, así el front (otro subdominio) puede leerla.
# PROD: estudiocontablest.com.ar (la cookie la setea api.<dominio> y la lee el front en <dominio>).
# DEV: dejar vacío (host-only localhost, ya compartido entre :5173 y :3000).
COOKIE_DOMAIN=

# Remitente de los emails transaccionales. El dominio DEBE estar verificado en Resend
# (recomendado: subdominio de envío, p.ej. send.<dominio>, para aislar reputación).
EMAIL_FROM=Sistema Contable <notificaciones@send.estudiocontablest.com.ar>

# Feature flag: 'true' habilita envío real vía Resend; cualquier otro valor
# loguea y skipea sin enviar. Mantener en 'false' fuera de producción.
EMAILS_ENABLED=false
